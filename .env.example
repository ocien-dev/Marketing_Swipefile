# Marketing Swipe File

# Runtime data root outside OneDrive. Keep local-only data here after MSF-R03.
MSF_DATA_DIR=C:\MSF-data\Marketing_Swipe_File

# Gold runtime policy. Windows is canonical; WSL is opt-in only after certification.
MSF_GOLD_RUNTIME=windows_native
MSF_GOLD_TEMP_DIR=C:\MSF-data\Marketing_Swipe_File\.tmp

# Supabase is not required for the local MVP foundation.
# Fill these only when starting the Supabase release.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local Codex MCP access for the Marketing Swipe File Supabase account.
# Do not put real tokens in this example file.
MSF_SUPABASE_PROJECT_REF=
MSF_SUPABASE_ACCESS_TOKEN=
