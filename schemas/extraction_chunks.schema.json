{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-swipe-file.local/schemas/extraction_chunks.schema.json",
  "title": "Extraction Chunk Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "episode_video_id",
    "chunking_strategy",
    "max_chars",
    "created_at",
    "chunks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "episode_video_id": {
      "type": "string",
      "minLength": 1
    },
    "chunking_strategy": {
      "type": "string"
    },
    "max_chars": {
      "type": "integer",
      "minimum": 1000
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chunk_id",
          "chunk_index",
          "title",
          "start_seconds",
          "end_seconds",
          "segment_count",
          "char_count",
          "file"
        ],
        "properties": {
          "chunk_id": {
            "type": "string",
            "minLength": 1
          },
          "chunk_index": {
            "type": "integer",
            "minimum": 0
          },
          "title": {
            "type": "string"
          },
          "chapter_title": {
            "type": ["string", "null"]
          },
          "part_index": {
            "type": "integer",
            "minimum": 1
          },
          "start_seconds": {
            "type": ["number", "null"],
            "minimum": 0
          },
          "end_seconds": {
            "type": ["number", "null"],
            "minimum": 0
          },
          "segment_count": {
            "type": "integer",
            "minimum": 0
          },
          "char_count": {
            "type": "integer",
            "minimum": 0
          },
          "file": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
