{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-swipe-file.local/schemas/gold_insights.schema.json",
  "title": "Marketing Swipe File Gold Insights",
  "type": "object",
  "required": ["schema_version", "insight_layer", "episode_video_id", "compatibility", "audit", "insights"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "insight_layer": {"const": "gold_extraction"},
    "episode_video_id": {"type": "string", "minLength": 1},
    "compatibility": {"type": "object"},
    "audit": {
      "type": "object",
      "required": ["status", "open_findings", "gate_source"],
      "properties": {
        "status": {"enum": ["pending_external", "passed"]},
        "open_findings": {"type": "integer", "minimum": 0},
        "gate_source": {"type": "string", "minLength": 1}
      }
    },
    "insights": {"type": "array", "items": {"$ref": "#/$defs/insight"}}
  },
  "$defs": {
    "citation": {
      "type": "object",
      "required": ["segment_id", "start_seconds", "end_seconds", "quote_verbatim"],
      "properties": {
        "segment_id": {"type": "string"},
        "start_seconds": {"type": "number", "minimum": 0},
        "end_seconds": {"type": "number", "minimum": 0},
        "quote_verbatim": {"type": "string", "minLength": 1}
      }
    },
    "number": {
      "type": "object",
      "required": ["raw", "value", "min_value", "max_value", "unit_kind", "period", "role", "value_status"],
      "properties": {
        "raw": {"type": "string", "minLength": 1},
        "value": {"type": ["number", "null"]},
        "min_value": {"type": ["number", "null"]},
        "max_value": {"type": ["number", "null"]},
        "unit_kind": {"enum": ["currency", "percent", "count", "duration", "ratio"]},
        "unit": {"type": ["string", "null"]},
        "period": {"type": ["string", "null"]},
        "role": {"enum": ["baseline", "result", "delta", "target", "price", "budget", "capacity", "cadence", "other"]},
        "value_status": {"enum": ["reported", "calculated", "corrected", "inferred"]},
        "denominator": {"type": ["string", "null"]},
        "attribution_window": {"type": ["string", "null"]}
      }
    },
    "insight": {
      "type": "object",
      "required": ["candidate_id", "chunk_id", "title", "type", "themes", "subthemes", "process_tags", "source_claim", "takeaway_applicavel", "context", "reported_case", "causal_certainty", "claim_risk", "numbers", "steps", "conditions", "caveats", "evidence", "relations"],
      "properties": {
        "candidate_id": {"type": "string", "minLength": 1},
        "chunk_id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 12},
        "type": {"enum": ["principle", "tactic", "playbook_step", "framework", "quantitative_case", "test_result", "copy_pattern", "script", "warning", "example"]},
        "themes": {"type": "array", "minItems": 1, "items": {"enum": ["audience_market", "business_model", "copywriting", "copy_vsl", "creative_strategy", "conversion_optimization", "delivery_support", "funnel_architecture", "launch_campaign", "offer_pricing", "operations_management", "paid_traffic", "product_strategy", "retention_ascension", "sales_relationship", "testing_measurement", "unit_economics"]}},
        "subthemes": {"type": "array", "items": {"type": "string"}},
        "process_tags": {"type": "array", "items": {"type": "string", "pattern": "^process-[a-z0-9-]+$"}},
        "source_claim": {"type": "string", "minLength": 1},
        "takeaway_applicavel": {"type": "string", "minLength": 35},
        "context": {"type": "object"},
        "reported_case": {"type": "boolean"},
        "causal_certainty": {"enum": ["direct_test", "reported_attribution", "correlation", "uncertain", "not_applicable"]},
        "claim_risk": {"enum": ["low", "medium", "high"]},
        "numbers": {"type": "array", "items": {"$ref": "#/$defs/number"}},
        "steps": {"type": "array", "items": {"type": "string"}},
        "conditions": {"type": "array", "items": {"type": "string"}},
        "caveats": {"type": "array", "items": {"type": "string"}},
        "evidence": {
          "type": "object",
          "required": ["minimal_quote", "context_range", "support_segments"],
          "properties": {
            "minimal_quote": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/citation"}},
            "context_range": {"type": "object"},
            "support_segments": {"type": "array", "items": {"$ref": "#/$defs/citation"}}
          }
        },
        "relations": {
          "type": "object",
          "required": ["parent_candidate_id", "child_candidate_ids"],
          "properties": {
            "parent_candidate_id": {"type": ["string", "null"]},
            "child_candidate_ids": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    }
  }
}
