{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-swipe-file.local/schemas/insights.schema.json",
  "title": "Extracted Marketing Insights",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "episode_video_id",
    "insights"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "episode_video_id": {
      "type": "string",
      "minLength": 1
    },
    "asset_id": {
      "type": ["string", "null"]
    },
    "insights": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "insight_id",
          "title",
          "insight_ptbr",
          "level",
          "insight_type",
          "themes",
          "applicability",
          "evidence",
          "confidence_score",
          "source_agent",
          "dedupe_key"
        ],
        "properties": {
          "insight_id": {
            "type": "string",
            "minLength": 1
          },
          "source_kind": {
            "type": "string",
            "enum": ["transcript", "description", "comment", "asset"]
          },
          "title": {
            "type": "string"
          },
          "insight_original": {
            "type": ["string", "null"]
          },
          "insight_ptbr": {
            "type": "string"
          },
          "summary_ptbr": {
            "type": ["string", "null"]
          },
          "level": {
            "type": "string",
            "enum": ["strategic", "tactical", "operational"]
          },
          "insight_type": {
            "type": "string",
            "enum": [
              "principle",
              "framework",
              "example",
              "warning",
              "tactic",
              "template",
              "case",
              "quote",
              "hypothesis",
              "playbook_step",
              "complete_copy",
              "partial_copy",
              "spreadsheet_model",
              "checklist"
            ]
          },
          "themes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "subthemes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applicability": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "niches": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "funnel_stages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "review_status": {
            "type": "string",
            "enum": ["auto_accepted", "needs_review", "reviewed", "rejected"]
          },
          "source_agent": {
            "type": "string"
          },
          "dedupe_key": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "evidence_id",
                "quote_original",
                "evidence_strength"
              ],
              "properties": {
                "evidence_id": {
                  "type": "string",
                  "minLength": 1
                },
                "segment_id": {
                  "type": ["string", "null"]
                },
                "episode_video_id": {
                  "type": ["string", "null"]
                },
                "asset_id": {
                  "type": ["string", "null"]
                },
                "start_seconds": {
                  "type": ["number", "null"],
                  "minimum": 0
                },
                "end_seconds": {
                  "type": ["number", "null"],
                  "minimum": 0
                },
                "page_number": {
                  "type": ["integer", "null"],
                  "minimum": 1
                },
                "sheet_name": {
                  "type": ["string", "null"]
                },
                "cell_range": {
                  "type": ["string", "null"]
                },
                "slide_number": {
                  "type": ["integer", "null"],
                  "minimum": 1
                },
                "quote_original": {
                  "type": "string"
                },
                "quote_ptbr": {
                  "type": ["string", "null"]
                },
                "evidence_strength": {
                  "type": "string",
                  "enum": ["weak", "medium", "strong"]
                }
              }
            }
          },
          "relations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["target_insight_id", "relation_type"],
              "properties": {
                "target_insight_id": {
                  "type": "string"
                },
                "relation_type": {
                  "type": "string",
                  "enum": ["supports", "contradicts", "extends", "example_of", "similar_to", "depends_on", "part_of", "applies_to"]
                },
                "rationale": {
                  "type": ["string", "null"]
                },
                "confidence_score": {
                  "type": ["number", "null"],
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          }
        }
      }
    }
  }
}

