{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-swipe-file.local/schemas/insights_v2.schema.json",
  "title": "Marketing Swipe File Insights V2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "insight_layer",
    "episode_video_id",
    "asset_id",
    "extraction_run",
    "insights"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "insight_layer": {
      "type": "string",
      "enum": ["raw_insights_v2", "curated_insights"]
    },
    "episode_video_id": {
      "type": "string",
      "minLength": 1
    },
    "asset_id": {
      "type": ["string", "null"]
    },
    "extraction_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "extraction_method",
        "route",
        "model",
        "prompt_version",
        "generated_at",
        "max_insights_per_chunk",
        "chunk_count",
        "input_chunk_ids",
        "cost"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "extraction_method": {
          "type": "string",
          "enum": ["heuristic_v1", "llm_v2"]
        },
        "route": {
          "type": "string",
          "enum": ["api", "codex_manual"]
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "prompt_version": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        },
        "max_insights_per_chunk": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "chunk_count": {
          "type": "integer",
          "minimum": 0
        },
        "input_chunk_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input_tokens", "output_tokens", "estimated_usd", "notes"],
          "properties": {
            "input_tokens": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "output_tokens": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "estimated_usd": {
              "type": ["number", "null"],
              "minimum": 0
            },
            "notes": {
              "type": ["string", "null"]
            }
          }
        }
      }
    },
    "insights": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/insight_v2"
      }
    }
  },
  "$defs": {
    "insight_v2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "insight_id",
        "source_kind",
        "extraction_method",
        "canonical_title",
        "title",
        "specific_takeaway",
        "insight_ptbr",
        "summary_ptbr",
        "use_case",
        "when_to_use",
        "when_not_to_use",
        "claim_risk",
        "evidence_cleanliness",
        "cluster_id",
        "supporting_insight_ids",
        "editorial_score",
        "level",
        "insight_type",
        "themes",
        "subthemes",
        "applicability",
        "niches",
        "funnel_stages",
        "confidence_score",
        "review_status",
        "source_agent",
        "dedupe_key",
        "source_chunk",
        "evidence",
        "relations",
        "reviewed_by",
        "reviewed_at"
      ],
      "properties": {
        "insight_id": {
          "type": "string",
          "minLength": 1
        },
        "source_kind": {
          "type": "string",
          "enum": ["transcript", "description", "comment", "asset"]
        },
        "extraction_method": {
          "type": "string",
          "enum": ["heuristic_v1", "llm_v2"]
        },
        "canonical_title": {
          "type": "string",
          "minLength": 8
        },
        "title": {
          "type": "string",
          "minLength": 8
        },
        "specific_takeaway": {
          "type": "string",
          "minLength": 20
        },
        "insight_ptbr": {
          "type": "string",
          "minLength": 20
        },
        "summary_ptbr": {
          "type": ["string", "null"]
        },
        "use_case": {
          "type": "string",
          "minLength": 8
        },
        "when_to_use": {
          "type": "string",
          "minLength": 8
        },
        "when_not_to_use": {
          "type": "string",
          "minLength": 8
        },
        "claim_risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "evidence_cleanliness": {
          "type": "string",
          "enum": ["clean", "minor_noise", "transcript_noise", "promo_contaminated"]
        },
        "cluster_id": {
          "type": ["string", "null"]
        },
        "supporting_insight_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "editorial_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "level": {
          "type": "string",
          "enum": ["strategic", "tactical", "operational"]
        },
        "insight_type": {
          "type": "string",
          "enum": [
            "principle",
            "framework",
            "example",
            "warning",
            "tactic",
            "template",
            "case",
            "quote",
            "hypothesis",
            "playbook_step",
            "complete_copy",
            "partial_copy",
            "spreadsheet_model",
            "checklist"
          ]
        },
        "themes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "subthemes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "applicability": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "niches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "funnel_stages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "process_tags": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^process-[a-z0-9-]+$"
          }
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "review_status": {
          "type": "string",
          "enum": ["draft", "needs_review", "reviewed", "auto_accepted", "rejected"]
        },
        "source_agent": {
          "type": "string",
          "minLength": 1
        },
        "dedupe_key": {
          "type": "string",
          "minLength": 1
        },
        "source_chunk": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "chunk_id",
            "chunk_index",
            "chunk_title",
            "chunk_file",
            "start_seconds",
            "end_seconds"
          ],
          "properties": {
            "chunk_id": {
              "type": ["string", "null"]
            },
            "chunk_index": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "chunk_title": {
              "type": ["string", "null"]
            },
            "chunk_file": {
              "type": ["string", "null"]
            },
            "start_seconds": {
              "type": ["number", "null"],
              "minimum": 0
            },
            "end_seconds": {
              "type": ["number", "null"],
              "minimum": 0
            }
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_v2"
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation"
          }
        },
        "reviewed_by": {
          "type": ["string", "null"]
        },
        "reviewed_at": {
          "type": ["string", "null"]
        }
      }
    },
    "evidence_v2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "segment_id",
        "episode_video_id",
        "asset_id",
        "chunk_id",
        "start_seconds",
        "end_seconds",
        "quote_original",
        "quote_ptbr",
        "evidence_strength",
        "locator"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "segment_id": {
          "type": ["string", "null"]
        },
        "episode_video_id": {
          "type": ["string", "null"]
        },
        "asset_id": {
          "type": ["string", "null"]
        },
        "chunk_id": {
          "type": ["string", "null"]
        },
        "start_seconds": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "end_seconds": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "page_number": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "sheet_name": {
          "type": ["string", "null"]
        },
        "cell_range": {
          "type": ["string", "null"]
        },
        "slide_number": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "quote_original": {
          "type": "string",
          "minLength": 1
        },
        "quote_ptbr": {
          "type": ["string", "null"]
        },
        "evidence_strength": {
          "type": "string",
          "enum": ["weak", "medium", "strong"]
        },
        "locator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["segment", "chunk", "asset_page", "asset_cell", "asset_slide"]
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_insight_id", "relation_type", "rationale", "confidence_score"],
      "properties": {
        "target_insight_id": {
          "type": "string"
        },
        "relation_type": {
          "type": "string",
          "enum": ["supports", "contradicts", "extends", "example_of", "similar_to", "depends_on", "part_of", "applies_to"]
        },
        "rationale": {
          "type": ["string", "null"]
        },
        "confidence_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
