{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-swipe-file.local/schemas/msf_process_skill_contract.schema.json",
  "title": "Marketing Swipe File Process Skill Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill_type",
    "skill_name",
    "display_name",
    "process_tags",
    "source_layer",
    "citation_policy",
    "writing_policy",
    "module_inheritance_policy",
    "output_contract",
    "required_files",
    "validation_checklist"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "skill_type": {
      "const": "msf_process_skill"
    },
    "skill_name": {
      "type": "string",
      "pattern": "^msf-process-[a-z0-9][a-z0-9-]{1,58}[a-z0-9]$"
    },
    "display_name": {
      "type": "string",
      "minLength": 3
    },
    "process_tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^process-[a-z0-9][a-z0-9-]*[a-z0-9]$"
      }
    },
    "source_layer": {
      "enum": [
        "curated_insights",
        "v2_master_pool"
      ]
    },
    "citation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "insight_claim",
        "generic_practice"
      ],
      "properties": {
        "insight_claim": {
          "const": "[insight:<insight_id>]"
        },
        "generic_practice": {
          "const": "[generic-practice]"
        }
      }
    },
    "writing_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "internal_playbook",
        "evidence_quotes",
        "final_outputs"
      ],
      "properties": {
        "internal_playbook": {
          "const": "ascii_nfkd"
        },
        "evidence_quotes": {
          "const": "verbatim_utf8"
        },
        "final_outputs": {
          "const": "pt_br_full_accents"
        }
      }
    },
    "module_inheritance_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_counting",
        "known_overlap_insight_ids",
        "scope_boundary"
      ],
      "properties": {
        "evidence_counting": {
          "const": "dedupe_insight_id_across_imported_modules"
        },
        "known_overlap_insight_ids": {
          "type": "array",
          "prefixItems": [
            {
              "const": "zoChfFHnlOQ-v2-0008"
            },
            {
              "const": "mCaFyZpXJdE-v2-0011"
            }
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "scope_boundary": {
          "const": "process_specific_logic_stays_in_skill_transversal_claims_stay_principle_level"
        }
      }
    },
    "required_files": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_checklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_from_test_briefing",
        "r09_rubric_evaluation",
        "blind_baseline_test",
        "playbook_claims_cited_or_generic"
      ],
      "properties": {
        "output_from_test_briefing": {
          "$ref": "#/$defs/check_status"
        },
        "r09_rubric_evaluation": {
          "$ref": "#/$defs/check_status"
        },
        "blind_baseline_test": {
          "$ref": "#/$defs/check_status"
        },
        "playbook_claims_cited_or_generic": {
          "$ref": "#/$defs/check_status"
        }
      }
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_binding",
        "claim_fence",
        "proof_fit",
        "testable_bet",
        "coherence_check"
      ],
      "properties": {
        "evidence_binding": {
          "const": "claims_must_be_bound_to_insight_or_generic_practice"
        },
        "claim_fence": {
          "const": "state_what_cannot_be_promised_for_money_health_esoteric_and_platform_claims"
        },
        "proof_fit": {
          "const": "state_how_each_core_claim_or_mechanism_can_be_proven_or_mark_it_proof_weak"
        },
        "testable_bet": {
          "const": "include_falsifiable_hypothesis_variants_metric_failure_signal_and_read_condition"
        },
        "coherence_check": {
          "const": "name_the_single_belief_when_combining_more_than_one_mechanism"
        }
      }
    }
  },
  "$defs": {
    "check_status": {
      "type": "string",
      "enum": [
        "pending",
        "pass",
        "fail"
      ]
    }
  }
}
